%% TASK 1 - READ TEMPERATURE DATA, PLOT, AND WRITE TO A LOG FILE [20 MARKS]

duration = 600;                     % Total acquisition time in seconds
tempData = zeros(1, duration);      % Preallocate array for temperature values
timeStamps = 0:1:duration-1;        % Time vector (seconds)

% Sensor specifications (from MCP9700A datasheet)
Tc = 0.01;      % Temperature coefficient (10 mV/°C)
V0C = 0.500;    % Output voltage at 0°C

% Read temperature every second (simulate with a loop)
for t = 1:duration
    voltage = readVoltage(a, 'A0');     % Read from analog pin A0
    tempData(t) = (voltage - V0C) / Tc; % Convert voltage to temperature
    pause(1);
end

% Calculate statistics
minTemp = min(tempData);
maxTemp = max(tempData);
avgTemp = mean(tempData);

% Plot temperature over time
figure;
plot(timeStamps, tempData);
xlabel('Time (s)');
ylabel('Temperature (°C)');
title('Capsule Temperature Monitoring');
